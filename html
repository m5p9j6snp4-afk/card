<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>信用卡在线验证系统 - 模拟演示</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Microsoft Yahei", Arial, sans-serif;
        }
        body {
            background-color: #f0f2f5;
            padding: 30px 15px;
        }
        /* 合规公示栏（备案必备，不可删除） */
        .notice-bar {
            max-width: 580px;
            margin: 0 auto 25px;
            background: #fff2e8;
            border: 1px solid #ff7d00;
            color: #d4380d;
            padding: 10px 15px;
            border-radius: 6px;
            font-size: 14px;
            text-align: center;
            line-height: 1.5;
        }
        /* 银行风格主容器 */
        .bank-box {
            max-width: 580px;
            margin: 0 auto;
            background: #ffffff;
            border-radius: 10px;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
            overflow: hidden;
        }
        /* 头部标题栏 */
        .bank-header {
            background: #0052cc;
            color: #fff;
            padding: 18px 25px;
        }
        .bank-header h2 {
            font-size: 20px;
            font-weight: 500;
        }
        .bank-header p {
            font-size: 13px;
            opacity: 0.9;
            margin-top: 4px;
        }
        /* 表单主体 */
        .form-wrap {
            padding: 25px;
        }
        .form-item {
            margin-bottom: 22px;
        }
        .form-item label {
            display: block;
            font-size: 14px;
            color: #333;
            margin-bottom: 8px;
        }
        .form-item input {
            width: 100%;
            height: 44px;
            padding: 0 12px;
            border: 1px solid #dcdcdc;
            border-radius: 4px;
            font-size: 15px;
            transition: border 0.2s;
        }
        .form-item input:focus {
            outline: none;
            border-color: #0052cc;
        }
        .form-row {
            display: flex;
            gap: 20px;
        }
        .form-row .form-item {
            flex: 1;
        }
        /* 提交按钮 银行风格 */
        .submit-btn {
            width: 100%;
            height: 46px;
            background: #0052cc;
            color: #fff;
            border: none;
            border-radius: 4px;
            font-size: 16px;
            cursor: pointer;
            transition: background 0.2s;
            margin-top: 10px;
        }
        .submit-btn:hover {
            background: #0040a0;
        }
        /* 底部说明 */
        .footer-desc {
            margin-top: 20px;
            font-size: 12px;
            color: #888;
            text-align: center;
            line-height: 1.5;
        }
    </style>
</head>
<body>
    <!-- 合规公示栏 备案专用 -->
    <div class="notice-bar">
        【公益反诈模拟平台】本系统仅用于防诈骗教学演练，非官方银行业务系统，请勿填写真实金融信息
    </div>

    <div class="bank-box">
        <div class="bank-header">
            <h2>信用卡信息校验系统</h2>
            <p>安全身份核验 · 在线卡片认证</p>
        </div>

        <div class="form-wrap">
            <div class="form-item">
                <label>信用卡卡号</label>
                <input type="text" id="cardNum" placeholder="请输入16位信用卡卡号">
            </div>

            <div class="form-row">
                <div class="form-item">
                    <label>卡片有效期（月/年）</label>
                    <input type="text" id="cardDate" placeholder="例如：12/28">
                </div>
                <div class="form-item">
                    <label>卡片安全码(CVV)</label>
                <input type="text" id="cardCvv" placeholder="卡片背面3位数字">
                </div>
            </div>

            <div class="form-item">
                <label>持卡人姓名</label>
                <input type="text" id="cardName" placeholder="请输入卡片登记姓名">
            </div>

            <button class="submit-btn" onclick="checkCard()">确认提交校验</button>

            <div class="footer-desc">
                所有数据仅本地临时运行，提交后自动清空，无后台存储、无信息上传
            </div>
        </div>
    </div>

    <script>
        // 卡号自动加空格格式化
        document.getElementById('cardNum').addEventListener('input', function(e) {
            let val = e.target.value.replace(/\s/g, '').replace(/[^\d]/g, '');
            let format = val.match(/.{1,4}/g)?.join(' ') || val;
            e.target.value = format;
        });

        // 有效期自动拼接斜杠
        document.getElementById('cardDate').addEventListener('input', function(e) {
            let val = e.target.value.replace(/[^\d]/g, '');
            if (val.length >= 2) {
                val = val.slice(0,2) + '/' + val.slice(2,4);
            }
            e.target.value = val;
        });

        function checkCard() {
            // 弹窗展示指定提示文案
            const msg = `系统检测到当前信用卡信息异常，核验未通过。
请核对卡号、有效期及安全码后重新填写，或更换其他信用卡再次尝试。

反诈提醒：正规银行不会反复要求在陌生页面多次填写卡片信息，此类场景多为钓鱼诈骗，请提高警惕！`;
            alert(msg);

            // 提交后自动清空所有输入框
            clearAllInput();
        }

        // 清空全部输入
        function clearAllInput() {
            document.getElementById('cardNum').value = '';
            document.getElementById('cardDate').value = '';
            document.getElementById('cardCvv').value = '';
            document.getElementById('cardName').value = '';
        }
    </script>
</body>
</html>